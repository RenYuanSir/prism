{
  "name": "ai-pr-review",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:frontend": "pnpm --filter @ai-pr-review/frontend dev",
    "dev:backend": "pnpm --filter @ai-pr-review/backend dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @ai-pr-review/shared build",
    "build:frontend": "pnpm --filter @ai-pr-review/frontend build",
    "build:backend": "pnpm --filter @ai-pr-review/backend build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json,css}": [
      "biome check --write --no-errors-on-unmatched",
      "biome format --write"
    ]
  },
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=18.0.0"
  }
}
