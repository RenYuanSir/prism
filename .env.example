# GitHub personal access token (required)
# Create one at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=***

# ============================================
# LLM Provider Configuration
# ============================================
# Each pipeline stage (summary, risk, suggestion) can use a different provider.
# Supported providers: anthropic, google, openai, openai-compatible
#
# For each stage, set:
#   LLM_<STAGE>_PROVIDER  - Provider type (default shown below)
#   LLM_<STAGE>_API_KEY   - API key for that provider
#   LLM_<STAGE>_MODEL     - Model name (default shown below)
#   LLM_<STAGE>_BASE_URL  - Optional: custom API base URL (for openai-compatible)
#
# If you only have one provider, set all stages to the same values.

# --- Summary Stage (fast, cheap model recommended) ---
# Default: Google Gemini
LLM_SUMMARY_PROVIDER=google
LLM_SUMMARY_API_KEY=***
LLM_SUMMARY_MODEL=gemini-2.0-flash

# --- Risk Analysis Stage (strong reasoning model recommended) ---
# Default: Anthropic Claude
LLM_RISK_PROVIDER=anthropic
LLM_RISK_API_KEY=***
LLM_RISK_MODEL=claude-3-5-sonnet-20241022

# --- Suggestion Stage (strong reasoning model recommended) ---
# Default: Anthropic Claude
LLM_SUGGESTION_PROVIDER=anthropic
LLM_SUGGESTION_API_KEY=***
LLM_SUGGESTION_MODEL=claude-3-5-sonnet-20241022

# --- Examples for popular third-party providers ---

# Example: DeepSeek (openai-compatible)
# LLM_SUMMARY_PROVIDER=openai-compatible
# LLM_SUMMARY_API_KEY=sk-...
# LLM_SUMMARY_MODEL=deepseek-chat
# LLM_SUMMARY_BASE_URL=https://api.deepseek.com/v1

# Example: OpenRouter (openai-compatible)
# LLM_RISK_PROVIDER=openai-compatible
# LLM_RISK_API_KEY=sk-or-...
# LLM_RISK_MODEL=anthropic/claude-3.5-sonnet
# LLM_RISK_BASE_URL=https://openrouter.ai/api/v1

# Example: SiliconFlow (openai-compatible)
# LLM_SUGGESTION_PROVIDER=openai-compatible
# LLM_SUGGESTION_API_KEY=sk-...
# LLM_SUGGESTION_MODEL=deepseek-ai/DeepSeek-V3
# LLM_SUGGESTION_BASE_URL=https://api.siliconflow.cn/v1

# Example: Moonshot AI (openai-compatible)
# LLM_RISK_PROVIDER=openai-compatible
# LLM_RISK_API_KEY=sk-...
# LLM_RISK_MODEL=moonshot-v1-8k
# LLM_RISK_BASE_URL=https://api.moonshot.cn/v1

# Example: Aliyun Bailian (openai-compatible)
# LLM_SUMMARY_PROVIDER=openai-compatible
# LLM_SUMMARY_API_KEY=sk-...
# LLM_SUMMARY_MODEL=qwen-max
# LLM_SUMMARY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Example: Zhipu AI (openai-compatible)
# LLM_SUMMARY_PROVIDER=openai-compatible
# LLM_SUMMARY_API_KEY=...
# LLM_SUMMARY_MODEL=glm-4
# LLM_SUMMARY_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Example: 01.AI (openai-compatible)
# LLM_RISK_PROVIDER=openai-compatible
# LLM_RISK_API_KEY=...
# LLM_RISK_MODEL=yi-large
# LLM_RISK_BASE_URL=https://api.01.ai/v1

# Backend server port (optional, defaults to 3001)
PORT=3001

# Node environment
NODE_ENV=development